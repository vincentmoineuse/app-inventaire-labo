# Copie ce fichier en ".streamlit/secrets.toml" (en local) OU colle son contenu
# dans "Settings > Secrets" de ton application sur Streamlit Community Cloud.
# NE JAMAIS pousser un vrai secrets.toml sur GitHub (il est déjà exclu via .gitignore).

# URL du projet Supabase (Settings > API > Project URL)
supabase_url = "https://xxxxxxxxxxxxxxxxxxxx.supabase.co"

# Clé "service_role" du projet Supabase (Settings > API > Project API keys > service_role)
# ⚠️ Cette clé donne un accès complet à la base : ne la partage jamais, ne la mets jamais
# dans du code exposé côté navigateur. Ici elle reste côté serveur (Streamlit Secrets), c'est sûr.
supabase_key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....."
